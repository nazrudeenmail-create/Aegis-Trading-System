# Aegis Trading System — Backend Environment Template
#
# Copy this file to .env and fill in the values.
# Never commit .env to Git.
#
# The setup script (scripts/setup.sh / setup.ps1) auto-generates
# SECRET_KEY on first install. You only need to edit values below
# if your environment differs from the defaults.

# Application
APP_ENV=development
APP_NAME=Aegis Trading System
APP_VERSION=0.1.0
DEBUG=True

# Database (psycopg3 format: postgresql+psycopg://user:password@host:port/dbname)
# Change this to match your local PostgreSQL credentials.
DATABASE_URL=postgresql+psycopg://ats_user:ats_password@localhost:5432/ats_development

# Security — auto-generated by setup script on first install.
# To regenerate manually: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_secret

# CORS — allowed frontend origins.
# Accepts JSON array OR comma-separated string:
#   ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
#   ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:5173"]