# Aegis Trading System — Backend Environment Template
#
# Copy this file to .env and fill in the values.
# Never commit .env to Git.
#
# The setup script (scripts/setup.sh / setup.ps1) auto-generates
# SECRET_KEY on first install. You only need to edit values below
# if your environment differs from the defaults.

# ============================================================
# Application
# ============================================================
APP_ENV=development
APP_NAME=Aegis Trading System
APP_VERSION=0.1.0
DEBUG=True

# ============================================================
# Database
# Format: postgresql+psycopg://user:password@host:port/dbname
# Change this to match your local PostgreSQL credentials.
# ============================================================
DATABASE_URL=postgresql+psycopg://ats_user:ats_password@localhost:5432/ats_development

# ============================================================
# Security
# Auto-generated by setup script on first install.
# To regenerate manually: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
SECRET_KEY=replace_with_random_secret

# ============================================================
# CORS — allowed frontend origins.
# Accepts JSON array OR comma-separated string:
#   ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
#   ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# ============================================================
ALLOWED_ORIGINS=["http://localhost:5173"]

# ============================================================
# Broker & Account Mode
# 
# BROKER: Which broker to use (currently only "capital")
# ACCOUNT_MODE: demo or live
#   demo — paper/virtual money trading (DEFAULT)
#   live — real money trading (use with extreme caution!)
#
# These two variables are the SINGLE source of truth for
# which environment ATS connects to.
# ============================================================
BROKER=capital
ACCOUNT_MODE=demo

# ============================================================
# Capital.com API URLs
# 
# Capital.com has SEPARATE URLs for demo and live.
# The app automatically selects the correct one based on
# ACCOUNT_MODE above. You should not need to change these.
# ============================================================
CAPITAL_COM_DEMO_URL=https://demo-api-capital.backend-capital.com/api/v1
CAPITAL_COM_LIVE_URL=https://api-capital.backend-capital.com/api/v1

# ============================================================
# Capital.com Broker Credentials — REQUIRED
# 
# The app will EXIT on startup if these are empty!
# Get your API key from: https://capital.com/trading-platform/api-settings
# 
# NOTE: Enable "Demo" permissions on your API key for demo mode.
# ============================================================
CAPITAL_COM_API_KEY=
CAPITAL_COM_USERNAME=
CAPITAL_COM_PASSWORD=

# ============================================================
# Market Data Settings
# Number of historical candles to fetch on first sync.
# Increase for more backtest data (e.g., 5000).
# ============================================================
INITIAL_HISTORY_CANDLES=1000