# Aegis Trading System — Backend Environment Template
#
# Copy this file to .env and fill in the values.
# Never commit .env to Git.
#
# All variables are required unless marked (optional).

# Application
APP_ENV=                        # development | testing | production
APP_NAME=Aegis Trading System
APP_VERSION=0.1.0
DEBUG=                          # True | False

# Database (psycopg3 format: postgresql+psycopg://user:password@host:port/dbname)
DATABASE_URL=

# Security
SECRET_KEY=                     # Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# CORS (JSON array of allowed frontend origins)
ALLOWED_ORIGINS=                # Example: ["http://localhost:5173"]
